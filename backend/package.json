{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate:up": "dotenv -e .env -- node-pg-migrate up -j ts",
    "migrate:down": "dotenv -e .env -- node-pg-migrate down -j ts",
    "migrate:create": "node-pg-migrate create -j ts",
    "build": "node esbuild.cjs",
    "seed": "tsx src/seed.ts",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "typecheck": "tsc --noEmit",
    "gen": "kysely-codegen --exclude-pattern=\"Pgmigrations\" --out-file ./src/db/schema.generated.ts",
    "pasetoKeys": "dotenv -e .env -- tsx scripts/generate-keys.ts"
  },
  "dependencies": {
    "@app/shared": "workspace:*",
    "@hono/node-server": "^1.19.6",
    "@node-rs/argon2": "^2.0.2",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "arktype": "^2.2.0",
    "axios": "^1.13.2",
    "date-fns": "^4.2.1",
    "hono": "^4.12.18",
    "kysely": "^0.28.15",
    "paseto": "^3.1.4",
    "pg": "^8.20.0",
    "radash": "^12.1.1",
    "senselogs": "^1.0.7",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.19.30",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.6.1",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.28.0",
    "kysely-codegen": "^0.20.0",
    "node-pg-migrate": "^8.0.4"
  }
}
